// ─── Scanner Animation (SVG-style Compose Canvas) ─────────────────────────────

@Composable
fun BlipScannerAnimation(
    modifier: Modifier = Modifier,
    color: Color = BlipColors.Primary,
    isActive: Boolean = true
) {
    val infiniteTransition = rememberInfiniteTransition(label = "scanner")

    // Rotating sweep angle
    val sweepAngle by infiniteTransition.animateFloat(
        initialValue = 0f, targetValue = 360f,
        animationSpec = infiniteRepeatable(
            animation = tween(2200, easing = LinearEasing),
            repeatMode = RepeatMode.Restart
        ), label = "sweep"
    )

    // Pulsing ring scale
    val ringScale1 by infiniteTransition.animateFloat(
        initialValue = 0.3f, targetValue = 1f,
        animationSpec = infiniteRepeatable(
            animation = tween(2000, easing = FastOutSlowInEasing),
            repeatMode = RepeatMode.Restart
        ), label = "ring1"
    )
    val ringScale2 by infiniteTransition.animateFloat(
        initialValue = 0.3f, targetValue = 1f,
        animationSpec = infiniteRepeatable(
            animation = tween(2000, delayMillis = 700, easing = FastOutSlowInEasing),
            repeatMode = RepeatMode.Restart
        ), label = "ring2"
    )
    val ringScale3 by infiniteTransition.animateFloat(
        initialValue = 0.3f, targetValue = 1f,
        animationSpec = infiniteRepeatable(
            animation = tween(2000, delayMillis = 1400, easing = FastOutSlowInEasing),
            repeatMode = RepeatMode.Restart
        ), label = "ring3"
    )

    val ringAlpha1 = (1f - ringScale1).coerceIn(0f, 1f)
    val ringAlpha2 = (1f - ringScale2).coerceIn(0f, 1f)
    val ringAlpha3 = (1f - ringScale3).coerceIn(0f, 1f)

    Canvas(modifier = modifier) {
        val cx = size.width / 2f
        val cy = size.height / 2f
        val maxR = minOf(cx, cy)

        if (isActive) {
            // ── Pulsing rings ──
            drawCircle(
                color = color.copy(alpha = ringAlpha1 * 0.25f),
                center = Offset(cx, cy),
                radius = maxR * ringScale1,
                style = Stroke(width = 2.5f)
            )
            drawCircle(
                color = color.copy(alpha = ringAlpha2 * 0.18f),
                center = Offset(cx, cy),
                radius = maxR * ringScale2,
                style = Stroke(width = 2f)
            )
            drawCircle(
                color = color.copy(alpha = ringAlpha3 * 0.12f),
                center = Offset(cx, cy),
                radius = maxR * ringScale3,
                style = Stroke(width = 1.5f)
            )

            // ── Sweep gradient arc ──
            val sweepBrush = Brush.sweepGradient(
                0f to Color.Transparent,
                0.7f to Color.Transparent,
                1f to color.copy(alpha = 0.5f),
                center = Offset(cx, cy)
            )
            rotate(degrees = sweepAngle, pivot = Offset(cx, cy)) {
                drawArc(
                    brush = sweepBrush,
                    startAngle = -90f,
                    sweepAngle = 300f,
                    useCenter = true,
                    topLeft = Offset(cx - maxR * 0.85f, cy - maxR * 0.85f),
                    size = androidx.compose.ui.geometry.Size(maxR * 1.7f, maxR * 1.7f)
                )
            }

            // ── Sweep leading line ──
            rotate(degrees = sweepAngle - 90f, pivot = Offset(cx, cy)) {
                drawLine(
                    color = color.copy(alpha = 0.9f),
                    start = Offset(cx, cy),
                    end = Offset(cx, cy - maxR * 0.85f),
                    strokeWidth = 2f
                )
            }
        }

        // ── Static crosshair rings ──
        listOf(0.28f, 0.55f, 0.85f).forEach { fraction ->
            drawCircle(
                color = color.copy(alpha = 0.15f),
                center = Offset(cx, cy),
                radius = maxR * fraction,
                style = Stroke(width = 1.2f)
            )
        }

        // ── Center dot ──
        drawCircle(color = color, center = Offset(cx, cy), radius = 5f)
        drawCircle(
            color = color.copy(alpha = 0.3f),
            center = Offset(cx, cy),
            radius = 12f,
            style = Stroke(width = 1.5f)
        )

        // ── Crosshair tick marks ──
        val tickLen = 8f
        val outerR = maxR * 0.85f
        listOf(0f, 90f, 180f, 270f).forEach { deg ->
            val rad = Math.toRadians(deg.toDouble())
            val dx = Math.cos(rad).toFloat()
            val dy = Math.sin(rad).toFloat()
            drawLine(
                color = color.copy(alpha = 0.4f),
                start = Offset(cx + dx * (outerR - tickLen), cy + dy * (outerR - tickLen)),
                end   = Offset(cx + dx * outerR, cy + dy * outerR),
                strokeWidth = 2f
            )
        }
    }
}

// ─── SVG-style Bluetooth Icon (no emoji) ─────────────────────────────────────

@Composable
fun BluetoothSvgIcon(modifier: Modifier = Modifier, color: Color = Color.White) {
    Canvas(modifier = modifier) {
        val w = size.width
        val h = size.height
        val cx = w / 2f
        val strokeW = w * 0.08f

        // Vertical center line
        drawLine(color = color, start = Offset(cx, 0f), end = Offset(cx, h), strokeWidth = strokeW)
        // Top-right diagonal
        drawLine(color = color, start = Offset(cx, 0f), end = Offset(cx + w * 0.35f, h * 0.3f), strokeWidth = strokeW)
        drawLine(color = color, start = Offset(cx + w * 0.35f, h * 0.3f), end = Offset(cx - w * 0.35f, h * 0.7f), strokeWidth = strokeW)
        // Bottom-right diagonal
        drawLine(color = color, start = Offset(cx, h), end = Offset(cx + w * 0.35f, h * 0.7f), strokeWidth = strokeW)
        drawLine(color = color, start = Offset(cx + w * 0.35f, h * 0.7f), end = Offset(cx - w * 0.35f, h * 0.3f), strokeWidth = strokeW)
    }
}

// ─── SVG-style Radio/Mesh Icon ────────────────────────────────────────────────

@Composable
fun RadioWaveSvgIcon(modifier: Modifier = Modifier, color: Color = BlipColors.Primary) {
    Canvas(modifier = modifier) {
        val cx = size.width / 2f
        val cy = size.height * 0.65f
        val strokeW = size.width * 0.07f

        // Center dot
        drawCircle(color = color, center = Offset(cx, cy), radius = size.width * 0.08f)

        // Arcs (3 concentric)
        listOf(0.25f, 0.45f, 0.65f).forEach { fraction ->
            val r = size.width * fraction
            drawArc(
                color = color.copy(alpha = 1f - fraction * 0.4f),
                startAngle = 210f,
                sweepAngle = 120f,
                useCenter = false,
                topLeft = Offset(cx - r, cy - r),
                size = androidx.compose.ui.geometry.Size(r * 2, r * 2),
                style = Stroke(width = strokeW)
            )
        }
    }
}

// ─── Chat Bubble SVG Icon ─────────────────────────────────────────────────────

@Composable
fun ChatBubbleSvgIcon(modifier: Modifier = Modifier, color: Color = BlipColors.Primary) {
    Canvas(modifier = modifier) {
        val w = size.width
        val h = size.height
        val r = w * 0.18f

        // Rounded rect bubble
        drawRoundRect(
            color = color.copy(alpha = 0.15f),
            topLeft = Offset(0f, 0f),
            size = androidx.compose.ui.geometry.Size(w, h * 0.75f),
            cornerRadius = androidx.compose.ui.geometry.CornerRadius(r, r)
        )
        drawRoundRect(
            color = color,
            topLeft = Offset(0f, 0f),
            size = androidx.compose.ui.geometry.Size(w, h * 0.75f),
            cornerRadius = androidx.compose.ui.geometry.CornerRadius(r, r),
            style = Stroke(width = w * 0.06f)
        )

        // Tail
        val tailPath = androidx.compose.ui.graphics.Path().apply {
            moveTo(w * 0.2f, h * 0.72f)
            lineTo(w * 0.1f, h * 0.95f)
            lineTo(w * 0.35f, h * 0.72f)
            close()
        }
        drawPath(tailPath, color = color)

        // Dots inside
        listOf(0.3f, 0.5f, 0.7f).forEach { fx ->
            drawCircle(color = color, center = Offset(w * fx, h * 0.37f), radius = w * 0.07f)
        }
    }
}
